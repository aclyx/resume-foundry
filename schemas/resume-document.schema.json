                    "tags": {
                      "minItems": 1,
                      "type": "array",
                      "items": {
                        "type": "string",
                        "minLength": 1,
                        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
                      }
                    },
                    "priority": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 100
                    },
                    "density": {
                      "type": "string",
                      "enum": [
                        "compact",
                        "standard",
                        "spacious"
                      ]
                    }
