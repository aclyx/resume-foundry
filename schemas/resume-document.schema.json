            "canonical-json",
            "canonical-yaml",
            "markdown-frontmatter",
            "json-resume",
            "manual"
          ]
        },
        "density": {
          "type": "string",
          "enum": [
            "compact",
            "standard",
            "spacious"
          ]
        },
        "tags": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          }
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
