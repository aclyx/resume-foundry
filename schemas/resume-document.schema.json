                  "minimum": 0,
                  "maximum": 100
                },
                "density": {
                  "type": "string",
                  "enum": [
                    "compact",
                    "standard",
                    "spacious"
                  ]
                },
                "summary": {
                  "type": "string",
                  "minLength": 1
