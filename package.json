{
  "name": "resume-foundry",
  "version": "0.1.0",
  "description": "Render structured resume data into themed HTML, PDF, and Markdown outputs.",
  "type": "module",
  "license": "MIT",
  "author": "Alex Leung",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aclyx/resume-foundry.git"
  },
  "bugs": {
    "url": "https://github.com/aclyx/resume-foundry/issues"
  },
  "homepage": "https://github.com/aclyx/resume-foundry#readme",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22.13.0"
  },
  "bin": {
    "resume-foundry": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "fixtures",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist coverage",
    "lint": "eslint . --max-warnings=0",
    "resume-foundry": "node dist/cli.js",
    "schema": "pnpm build && node dist/scripts/generate-json-schema.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.0.3",
    "eslint": "^9.29.0",
    "pdfjs-dist": "^6.0.227",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^3.2.3"
  },
  "dependencies": {
    "mdast-util-to-markdown": "^2.1.2",
    "playwright": "^1.60.0",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
